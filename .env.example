# Local environment template for Nuvanx System
# IMPORTANT: Do NOT commit real secrets. This file is a template only.
# Copy this file to .env.local or .env.tokens.local and fill in the values locally.
# Use GitHub Actions Secrets for CI/production; never store production secrets in the repo.

# Public client variables (exposed to browser) - these are safe to be non-secret but still treat carefully
# VITE_ variables are embedded in the frontend bundle and are visible to end users.
VITE_API_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co/functions/v1/api
VITE_API_BASE_URL=
VITE_SUPABASE_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_SUPABASE_FIGMA_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co
VITE_SUPABASE_FIGMA_ANON_KEY=YOUR_VITE_SUPABASE_FIGMA_ANON_KEY
VITE_SENTRY_DSN=

# Private secrets (never expose these in client code or commit them)
META_ACCESS_TOKEN=YOUR_META_ACCESS_TOKEN
META_AD_ACCOUNT_ID=YOUR_META_AD_ACCOUNT_ID
GOOGLE_ADS_SERVICE_ACCOUNT=YOUR_GOOGLE_ADS_SERVICE_ACCOUNT_JSON
GOOGLE_ADS_DEVELOPER_TOKEN=YOUR_GOOGLE_ADS_DEVELOPER_TOKEN
GOOGLE_ADS_CUSTOMER_ID=YOUR_GOOGLE_ADS_CUSTOMER_ID
DOCTORALIA_SHEET_ID=YOUR_DOCTORALIA_SHEET_ID
DOCTORALIA_DRIVE_FILE_ID=YOUR_DOCTORALIA_DRIVE_FILE_ID
DATABASE_URL=postgresql://user:password@host:port/dbname
CLINIC_ID=YOUR_CLINIC_ID
REPORT_USER_ID=YOUR_REPORT_USER_ID
SUPABASE_ACCESS_TOKEN=YOUR_SUPABASE_ACCESS_TOKEN
SUPABASE_PROJECT_REF=YOUR_SUPABASE_PROJECT_REF
SUPABASE_DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD
PRODUCTION_E2E_URL=YOUR_PRODUCTION_E2E_URL
PRODUCTION_E2E_TOKEN=YOUR_PRODUCTION_E2E_TOKEN

# Frontend environment variables (Vite)
#
# BEST PRACTICE: Do NOT maintain a separate frontend/.env for production.
# The root sync script (scripts/sync-platform-secrets.js) writes to frontend/.env.local
# using values from the root .env.tokens.local.
#
# For local development:
#   1. Copy this file to frontend/.env.local
#   2. Or simply run `node scripts/sync-platform-secrets.js` from the project root
#      (it will create frontend/.env.local automatically from the root secrets).
#
# Only the VITE_* variables are bundled into the client.

VITE_SUPABASE_URL=https://ssvvuuysgxyqvmovrlvk.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_FIGMA_URL=
VITE_SUPABASE_FIGMA_ANON_KEY=
VITE_SENTRY_DSN=
VITE_MCP_API_KEY=your-mcp-key
VITE_API_BASE_URL=   # usually not needed
VITE_API_URL=        # usually not needed

# ─────────────────────────────────────────────────────────────────────────────
# Meta Assets (exposed to browser via Vite)
# These feed frontend/src/config/metaAccounts.ts
# ─────────────────────────────────────────────────────────────────────────────
VITE_META_ACCOUNT_IDS=act_9523446201036125,act_4172099716404860
VITE_META_FACEBOOK_PAGE_ID=685010274687129
VITE_META_INSTAGRAM_ACCOUNT_ID=599157696620256


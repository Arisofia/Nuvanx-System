VITE_API_URL=http://localhost:3001

# ── Supabase (required for online auth and cross-device sync) ─────────────────
# Get from: Supabase Dashboard → Connect → Framework → "Add files" panel
VITE_SUPABASE_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
# Legacy fallback (still accepted if VITE_SUPABASE_PUBLISHABLE_KEY is not set)
# VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Figma V.1 Supabase project (if separate from main; otherwise use same URL/key)
VITE_SUPABASE_FIGMA_URL=https://YOUR_SUPABASE_PROJECT_REF.supabase.co
VITE_SUPABASE_FIGMA_ANON_KEY=your-figma-anon-key-here

# Sentry error tracking
VITE_SENTRY_DSN=

# .env.webhooks.example
# Copia este archivo a .env.webhooks y rellena con tus valores reales

SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# URL que obtuviste después de "Implementar" en Google Apps Script
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/<SCRIPT_ID>/exec

# La misma clave que pusiste en EXPECTED_SECRET dentro de tu Google Apps Script
# Valor exacto solicitado:
SHEETS_WEBHOOK_SECRET=
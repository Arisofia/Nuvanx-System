# Server
PORT=3001
NODE_ENV=development

# Security (NEVER commit real values)
JWT_SECRET=your-jwt-secret-here-minimum-32-chars
ENCRYPTION_KEY=your-aes-256-key-here-minimum-32-chars

# Database (PostgreSQL connection string)
# Use DATABASE_URL for a self-hosted/managed Postgres instance, or
# set SUPABASE_DATABASE_KEY to the Supabase connection string (used as fallback)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.ssvvuuysgxyqvmovrlvk.supabase.co:5432/postgres
SUPABASE_DATABASE_KEY=

# Supabase main project
SUPABASE_URL=https://ssvvuuysgxyqvmovrlvk.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Figma V.1 project (if separate)
SUPABASE_FIGMA_URL=https://ssvvuuysgxyqvmovrlvk.supabase.co
SUPABASE_FIGMA_ANON_KEY=your-figma-anon-key-here
SUPABASE_FIGMA_SERVICE_ROLE=your-figma-service-role-key-here

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# ── Server-level API key defaults ─────────────────────────────────────────────
# These are used as fallbacks when no per-user credential is stored in the vault.
# Set via Codespaces secrets or your deployment platform — NEVER commit real values.

# AI providers
OPENAI_API_KEY=
GEMINI_API_KEY=

# Google (OAuth access token or API key)
GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=

# HubSpot CRM
# Use a Private App access token (recommended) or legacy API key
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_API_KEY=
HUBSPOT_PORTAL_ID=

# Meta (Facebook) Marketing API
# Use a long-lived Page/System User access token
META_ACCESS_TOKEN=
# Ad account ID in act_XXXXXXXXX format
META_AD_ACCOUNT_ID=

# WhatsApp Business Cloud API
# Use the same Meta System User access token or a dedicated WhatsApp token
WHATSAPP_ACCESS_TOKEN=
# Phone Number ID from the WhatsApp Business app (numeric, 10-20 digits)
# When set, WhatsApp is included in the GET /api/integrations/validate-all check.
WHATSAPP_PHONE_NUMBER_ID=2786365854888664

# Supabase JWT secret — enables the backend to accept Supabase access tokens
# Found at: Supabase project → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# Backend development environment sample
NODE_ENV=development
PORT=3001
JWT_SECRET=replace-with-a-secure-32-character-string
ENCRYPTION_KEY=replace-with-a-secure-32-character-string
BCRYPT_ROUNDS=12

# PostgreSQL / Supabase database
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.ssvvuuysgxyqvmovrlvk.supabase.co:5432/postgres

# Supabase admin clients
SUPABASE_URL=https://ssvvuuysgxyqvmovrlvk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-main-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Figma Supabase admin client
SUPABASE_FIGMA_URL=https://zpowfbeftxexzidlxndy.supabase.co
SUPABASE_FIGMA_SERVICE_ROLE=your-figma-supabase-service-role-key

# Optional API keys
OPENAI_API_KEY=
GEMINI_API_KEY=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WEBHOOK_ADMIN_USER_ID=

# If you want local testing without production credentials, leave optional keys blank.
# Required values for startup: JWT_SECRET, ENCRYPTION_KEY, DATABASE_URL (or SUPABASE_DATABASE_KEY in production)

# Server
PORT=3001
NODE_ENV=development

# Security (NEVER commit real values)
JWT_SECRET=your-jwt-secret-here-minimum-32-chars
ENCRYPTION_KEY=your-aes-256-key-here-minimum-32-chars

# Database (PostgreSQL connection string)
# Use DATABASE_URL for a self-hosted/managed Postgres instance, or
# set SUPABASE_DATABASE_KEY to the Supabase connection string (used as fallback)
DATABASE_URL=postgresql://user:password@localhost:5432/nuvanx
SUPABASE_DATABASE_KEY=

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# ── Server-level API key defaults ─────────────────────────────────────────────
# These are used as fallbacks when no per-user credential is stored in the vault.
# Set via Codespaces secrets or your deployment platform — NEVER commit real values.

# AI providers
OPENAI_API_KEY=
GEMINI_API_KEY=

# Google (OAuth access token or API key)
GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=

# HubSpot CRM
# Use a Private App access token (recommended) or legacy API key
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_API_KEY=
HUBSPOT_PORTAL_ID=

# Server
PORT=3001
NODE_ENV=development

# Security (NEVER commit real values)
JWT_SECRET=your-jwt-secret-here-minimum-32-chars
ENCRYPTION_KEY=your-aes-256-key-here-minimum-32-chars

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/nuvanx

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Integration credentials are stored encrypted in the database
# NEVER put API keys here or in the frontend

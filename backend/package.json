{
  "name": "nuvanx-rip-backend",
  "version": "1.0.0",
  "description": "Revenue Intelligence Platform - Backend API",
  "main": "src/server.js",
  "scripts": {
    "build": "echo \"No backend build step required\"",
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --forceExit --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "jest": {
    "transform": {
      "^.+\\.(js|ts)$": "babel-jest"
    },
    "moduleFileExtensions": [
      "js",
      "ts",
      "json",
      "node"
    ]
  },
  "babel": {
    "presets": [
      "@babel/preset-env",
      "@babel/preset-typescript"
    ]
  },
  "dependencies": {
    "@sentry/node": "10.46.0",
    "@supabase/supabase-js": "^2.103.0",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.5",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "libsodium-wrappers": "^0.8.4",
    "nuvanx-system": "file:..",
    "pg": "^8.11.3",
    "uuid": "^14.0.0",
    "winston": "^3.12.0"
  },
  "overrides": {
    "@fastify/otel": {
      "minimatch": "10.0.3"
    },
    "svix": "1.92.2"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-typescript": "^7.28.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "nodemon": "3.1.4",
    "supertest": "^6.3.4"
  }
}

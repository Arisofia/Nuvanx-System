# Render environment variables for nuvanx-backend
# The deploy script (scripts/deploy-render.ps1) reads from backend/.env
# and pushes to Render automatically. Add RENDER_API_KEY to backend/.env.
#
# NEVER commit backend/.env — it must stay in .gitignore.

# ── Render deploy automation ─────────────────────────────────────────────────
RENDER_API_KEY=rnd_...    # Get from: dashboard.render.com/u/settings/api-keys

# ── Production overrides (set automatically by deploy script) ────────────────
NODE_ENV=production
PORT=10000
FRONTEND_URL=https://frontend-arisofias-projects-c2217452.vercel.app

# ── Core secrets (copied from backend/.env by deploy script) ─────────────────
JWT_SECRET=
ENCRYPTION_KEY=
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_FIGMA_URL=
SUPABASE_FIGMA_ANON_KEY=
SUPABASE_FIGMA_SERVICE_ROLE=
WEBHOOK_ADMIN_USER_ID=cadf0cd6-cc44-4d66-864a-5bb687bfd4f5

# ── Meta / WhatsApp ───────────────────────────────────────────────────────────
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=nuvanx_verify_token_5a6b7c8d9e0f1a2b3c4d5
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
GITHUB_PAT=
SENTRY_DSN=
RESEND_API_KEY=
EMAIL_FROM=
BCRYPT_ROUNDS=12
JWT_EXPIRES_IN=7d
ALLOW_SHARED_CREDENTIALS=false

# --- Doctoralia Sheet Identification (use the correct ID below) ---
DOCTORALIA_SHEET_ID=1GAJoASGdjsKB7bTtC5hXPFkWbB7S4fVXhKD_cZoDwPw
DOCTORALIA_DRIVE_FILE_ID=1GAJoASGdjsKB7bTtC5hXPFkWbB7S4fVXhKD_cZoDwPw

# --- Your Clinic Context ---
CLINIC_ID=4207023b-eac1-4249-bf0f-d9b1e36a5d7a
DATABASE_URL=postgresql://...   # Use Supabase pooler URL (port 6543 recommended)

# --- Google Authentication (Recommended approach) ---
# Use a separate file (most secure)
GOOGLE_SA_JSON_FILE=secrets/doctoralia-service-account.json

# Alternative: Full JSON as environment variable (less ideal for .env files)
# GOOGLE_DOCTORALIA_SERVICE_ACCOUNT={"type":"service_account", ... full json ...}

# Alternative: Individual keys
# GOOGLE_API_KEY=...
# GOOGLE_CLIENT_EMAIL=...
# GOOGLE_CLIENT_ID=...
# GOOGLE_PROJECT_ID=...
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Strict validation (recommended) ---
# Set this to the same value as DOCTORALIA_SHEET_ID to prevent accidental use of wrong file
EXPECTED_DOCTORALIA_SHEET_ID=1GAJoASGdjsKB7bTtC5hXPFkWbB7S4fVXhKD_cZoDwPw

# --- Sync Behavior ---
DOCTORALIA_SYNC_PERMISSION_MODE=warn     # Use "warn" during debugging, "fail" in production

# Optional: Sheets webhook
SHEETS_WEBHOOK_SECRET=...
SHEETS_WEBHOOK_URL=...

# =============================================================================
# Doctoralia Financial Sync - Variables de entorno recomendadas
# =============================================================================
# Copia este archivo a .env (o .env.local) y rellena los valores reales.
# 
# Recomendación fuerte: Usa GOOGLE_SA_JSON_FILE apuntando a un archivo
# en la carpeta secrets/ (que está en .gitignore) en vez de pegar el JSON completo.
# =============================================================================

# --- Identificación del Sheet de Doctoralia ---
DOCTORALIA_SHEET_ID=tu-sheet-id-aqui
DOCTORALIA_DRIVE_FILE_ID=tu-sheet-id-aqui          # Normalmente igual que arriba

# --- Contexto de tu clínica ---
CLINIC_ID=tu-clinic-uuid-aqui
DATABASE_URL=postgresql://...@...supabase.co:5432/postgres   # Usa el pooler (puerto 6543) si es posible

# --- Autenticación con Google (elige una opción) ---

# Opción recomendada: Archivo JSON (más seguro y fácil de mantener)
GOOGLE_SA_JSON_FILE=secrets/doctoralia-service-account.json

# Opción alternativa: JSON completo como string (menos recomendado en .env)
# GOOGLE_DOCTORALIA_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Opción alternativa: Claves individuales (útil si no quieres el JSON completo)
# GOOGLE_API_KEY=tu-api-key
# GOOGLE_CLIENT_EMAIL=tu-service-account@proyecto.iam.gserviceaccount.com
# GOOGLE_CLIENT_ID=tu-client-id
# GOOGLE_PROJECT_ID=tu-project-id
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_CLAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"

# --- Validación opcional pero muy recomendada ---
# Si defines esto, el workflow fallará si accidentalmente usas otro sheet.
EXPECTED_DOCTORALIA_SHEET_ID=1zt2foEb7_64enii0UNj1X1J9AlU9hfcR

# --- Comportamiento del sync ---
DOCTORALIA_SYNC_PERMISSION_MODE=fail     # 'fail' o 'warn' si el service account no tiene permisos

# --- Opcional: Webhook de Sheets (si lo usas) ---
SHEETS_WEBHOOK_SECRET=tu-secreto-aqui
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/...

# Nota: El archivo secrets/doctoralia-service-account.json debe estar en .gitignore

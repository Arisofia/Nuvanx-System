# =============================================================================
# Doctoralia Financial Sync - Recommended Environment Variables
# =============================================================================
# Copy this file to .env or .env.local and fill in the real values.
#
# IMPORTANT: The correct Google Sheet ID (as of latest inspection) is:
# your-doctoralia-sheet-id-here
#
# The target tab is exactly: "Produccion Intermediarios"
# =============================================================================

# --- Doctoralia Sheet Identification ---
DOCTORALIA_SHEET_ID=your-doctoralia-sheet-id-here
DOCTORALIA_DRIVE_FILE_ID=your-doctoralia-sheet-id-here

# --- Your Clinic Context ---
CLINIC_ID=your-clinic-uuid-here
DATABASE_URL=

# --- Google Authentication (Strongly Recommended) ---
# Use a separate file (most secure + avoids secret scanning issues)
GOOGLE_SA_JSON_FILE=secrets/doctoralia-service-account.json

# Do NOT paste full service account JSONs or private keys directly into .env files.
# The scan-secrets job will block the workflow.

# Optional strict validation
EXPECTED_DOCTORALIA_SHEET_ID=your-doctoralia-sheet-id-here

# Sync behavior
DOCTORALIA_SYNC_PERMISSION_MODE=warn

# Optional webhook for Produccion Intermediarios
SHEETS_WEBHOOK_SECRET=
SHEETS_WEBHOOK_URL=

# For Doctoralia sheet (raw export tab) as per new sync spec
# Deploy Apps Script as Web App for "Doctoralia" sheet, use that URL
SHEETS_WEBHOOK_URL_DOCTORALIA=https://script.google.com/macros/s/AKfycbw...tu_codigo_aqui.../exec
SHEETS_WEBHOOK_SECRET_DOCTORALIA=Doctoralia_Secret_2026_!!

{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "vitest": ["node_modules/vitest/dist/index.d.ts"],
      "vitest/*": ["node_modules/vitest/dist/*.d.ts"]
    },
    "types": ["node"],
    "typeRoots": ["node_modules/@types", "node_modules/vitest", "frontend/node_modules/@types"]
  },
  "include": [
    "shared/**/*.ts",
    "supabase/functions/**/*.ts"
  ],
  "exclude": [
    "frontend",
    "backend",
    "**/node_modules"
  ]
}

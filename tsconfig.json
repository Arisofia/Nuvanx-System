{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "vitest": ["frontend/node_modules/vitest/dist/index.d.ts"],
      "vitest/*": ["frontend/node_modules/vitest/dist/*.d.ts"]
    },
    "typeRoots": ["frontend/node_modules/@types", "frontend/node_modules/vitest"]
  },
  "include": [
    "shared/**/*.ts"
  ],
  "exclude": [
    "frontend",
    "backend",
    "supabase",
    "**/node_modules"
  ]
}

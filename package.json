{
  "name": "nuvanx-system",
  "private": true,
  "version": "1.0.0",
  "description": "Unified workspace commands for Nuvanx System",
  "scripts": {
    "install:all": "npm --prefix backend install; npm --prefix frontend install",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "start:backend": "npm --prefix backend run start",
    "build:frontend": "npm --prefix frontend run build",
    "test:backend": "npm --prefix backend run test",
    "lint:frontend": "npm --prefix frontend run lint",
    "supabase:migration:list": "supabase migration list",
    "supabase:migration:push": "supabase db push",
    "supabase:types": "supabase gen types typescript --schema public > frontend/src/lib/supabase/types.ts",
    "supabase:figma:migration:push": "node scripts/apply-figma-migrations.js",
    "ingest:doctoralia": "NODE_PATH=backend/node_modules node scripts/ingest-doctoralia.js"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3"
  }
}
